    <div class="modal fade" id="modaleDettaglioKPIProf" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content shadow-lg">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="titoloModaleKPIProf">Dettaglio KPI</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-3" id="contenutoDettaglioKPIProf">
                    <div class="text-center text-muted py-4">
                        <div class="spinner-border text-success"></div>
                        <p class="mt-2 small">Caricamento in corso...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 💰 Modale Versamento da Credito Fatturabile a Plafond -->
    <div class="modal fade" id="modalVersaPlafond" tabindex="-1">
        <div class="modal-dialog">
            <form id="formVersaPlafond">
                <input type="hidden" name="ID_Cliente" value="@Model.ID_ClienteSelezionato" />

                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">
                            Versa in Plafond
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">

                        <!-- 👤 PROFESSIONISTA -->
                        <div class="mb-2">
                            <label>Professionista</label>
                            <input type="text"
                                   class="form-control form-control-sm"
                                   value="@Model.NomeCliente"
                                   readonly />
                        </div>

                        <!-- 💳 CREDITO DISPONIBILE -->
                        <div class="mb-2">
                            <label>Credito fatturabile disponibile (€)</label>
                            <input type="text"
                                   class="form-control form-control-sm"
                                   value="@Model.CreditoFatturabile.ToString("N2")"
                                   readonly />
                        </div>

                        <!-- 💰 IMPORTO -->
                        <div class="mb-2">
                            <label>Importo da versare (€)</label>
                            <input type="number"
                                   step="0.01"
                                   min="0"
                                   name="Importo"
                                   class="form-control form-control-sm"
                                   required />
                        </div>

                        <!-- 📝 NOTE -->
                        <div class="mb-2">
                            <label>Note</label>
                            <input type="text"
                                   name="Note"
                                   maxlength="200"
                                   class="form-control form-control-sm"
                                   placeholder="Es. Versamento per copertura spese" />
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="submit" class="btn btn-success btn-sm">
                            Conferma Versamento
                        </button>
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                            Annulla
                        </button>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <!-- 🏦 Modale Prelievo da Plafond -->
    <div class="modal fade" id="modalPrelevaPlafond" tabindex="-1">
        <div class="modal-dialog">
            <form id="formPrelevaPlafond">
                <input type="hidden" name="ID_Cliente" value="@Model.ID_ClienteSelezionato" />
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">
                            Preleva dal Plafond
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">

                        <!-- 👤 PROFESSIONISTA -->
                        <div class="mb-2">
                            <label>Professionista</label>
                            <input type="text"
                                   class="form-control form-control-sm"
                                   value="@Model.NomeCliente"
                                   readonly />
                        </div>

                        <!-- 💰 PLAFOND DISPONIBILE -->
                        <div class="mb-2">
                            <label>Plafond disponibile (€)</label>
                            <input type="text"
                                   id="plafondDisponibilePrelievo"
                                   class="form-control form-control-sm"
                                   readonly />
                        </div>

                        <!-- 💸 IMPORTO -->
                        <div class="mb-2">
                            <label>Importo da prelevare (€)</label>
                            <input type="number"
                                   step="0.01"
                                   min="0"
                                   name="Importo"
                                   class="form-control form-control-sm"
                                   required />
                        </div>

                        <!-- 📝 MOTIVAZIONE -->
                        <div class="mb-2">
                            <label>Motivazione</label>
                            <input type="text"
                                   name="Note"
                                   maxlength="200"
                                   class="form-control form-control-sm"
                                   placeholder="Es. Prelievo per liquidazione" />
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="submit" class="btn btn-danger btn-sm">
                            Conferma Prelievo
                        </button>
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                            Annulla
                        </button>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <script>
       function apriModaleOperazionePlafond(tipo) {

            if (tipo === 'versamento') {
                new bootstrap.Modal(
                    document.getElementById('modalVersaPlafond')
                ).show();
            }

            if (tipo === 'prelievo') {

                // 🔴 QUI STA IL PROBLEMA: il campo non veniva valorizzato
                document.getElementById("plafondDisponibilePrelievo").value =
                    "@Model.PlafondDisponibile.ToString("N2")";

                new bootstrap.Modal(
                    document.getElementById('modalPrelevaPlafond')
                ).show();
            }
        }

    </script>

    <script>
document.addEventListener("DOMContentLoaded", function () {

    document.querySelectorAll(".kpi-card").forEach(card => {

        card.addEventListener("click", function (e) {

            // 🔴 SE STO CLICCANDO SNAPSHOT → ESCO
            if (e.target.closest(".snapshot-link")) {
                return;
            }

            const tipo = this.dataset.tipo;
            const titolo = tipo.charAt(0).toUpperCase() + tipo.slice(1);

            const anno = "@annoSelezionato";
            const trimestre = "@Model.FiltroTrimestre";
            const sottoFiltro = "@Model.SottoFiltro";

            const modalElement = document.getElementById("modaleDettaglioKPIProf");
            const modal = new bootstrap.Modal(modalElement);

            document.getElementById("titoloModaleKPIProf").innerText =
                `Dettaglio KPI: ${titolo}`;

            document.getElementById("contenutoDettaglioKPIProf").innerHTML = `
                <div class="text-center text-muted py-4">
                    <div class="spinner-border text-success"></div>
                    <p class="mt-2 small">Caricamento dati ${titolo}...</p>
                </div>`;

            modal.show();

            const url =
                `/Home/GetDettaglioKPIProfessionista` +
                `?tipo=${encodeURIComponent(tipo)}` +
                `&anno=${encodeURIComponent(anno)}` +
                `&trimestre=${encodeURIComponent(trimestre)}` +
                `&sottoFiltro=${encodeURIComponent(sottoFiltro)}`;

            fetch(url)
                .then(res => res.text())
                .then(html => {
                    document.getElementById("contenutoDettaglioKPIProf").innerHTML = html;
                })
                .catch(err => {
                    document.getElementById("contenutoDettaglioKPIProf").innerHTML =
                        `<div class='alert alert-danger mb-0'>Errore: ${err.message}</div>`;
                });

        });

    });

});

// gestione filtro stato in lavorazione nel professionista sulle pratiche attive 
      document.addEventListener("change", function (e) {

    if (e.target.id === "filtroStatoPratiche") {

        const stato = e.target.value;

        const anno = "@annoSelezionato";
        const trimestre = "@Model.FiltroTrimestre";
        const sottoFiltro = "@Model.SottoFiltro";

        const container = document.getElementById("contenutoDettaglioKPIProf");

        // 🔄 spinner caricamento
        container.innerHTML = `
            <div class="text-center py-4 text-muted">
                <div class="spinner-border text-success"></div>
                <div class="small mt-2">Caricamento dati...</div>
            </div>
        `;

        fetch('/Home/GetDettaglioKPIProfessionista?tipo=pratiche'
            + '&anno=' + anno
            + '&trimestre=' + trimestre
            + '&sottoFiltro=' + sottoFiltro
            + '&filtroStato=' + stato)
            .then(r => r.text())
            .then(html => {

                container.innerHTML = html;

            })
            .catch(err => {

                container.innerHTML =
                    "<div class='alert alert-danger'>Errore caricamento dati</div>";

            });

    }

});

    </script>

    <script>
        // ===============================
        // 💰 VERSAMENTO → Credito → Plafond
        // ===============================
        document.getElementById("formVersaPlafond")
            ?.addEventListener("submit", function (e) {

                e.preventDefault();

                const formData = new FormData(this);

                fetch('/Home/VersaDaCreditoFatturabile', {
                    method: 'POST',
                    body: formData
                })
                    .then(r => r.json())
                    .then(res => {
                        if (res.success) {
                            location.reload();
                        } else {
                            alert(res.message);
                        }
                    })
                    .catch(() => alert("Errore versamento"));
            });


        // ===============================
        // 🏦 PRELIEVO → Plafond → Credito
        // ===============================
        document.getElementById("formPrelevaPlafond")
            ?.addEventListener("submit", function (e) {

                e.preventDefault();

                const formData = new FormData(this);

                fetch('/Home/PrelevaVersoCreditoFatturabile', {
                    method: 'POST',
                    body: formData
                })
                    .then(r => r.json())
                    .then(res => {
                        if (res.success) {
                            location.reload();
                        } else {
                            alert(res.message);
                        }
                    })
                    .catch(() => alert("Errore prelievo"));
            });
    </script>




    <div class="row g-3">

        <!-- Pratiche Attive -->
        <div class="col-md-4 col-sm-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-folder-fill me-1"></i> Pratiche Attive
                </div>
                <div class="card-body p-0">
                    @if (Model.Pratiche?.Any() == true)
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var p in Model.Pratiche.Take(5))
                            {
                                <li class="list-group-item small d-flex justify-content-between">
                                    <span>@p.Titolo</span>
                                    <a href="@Url.Action("DettaglioPratica", "Pratiche", new { id = p.ID_Pratiche })" class="text-primary">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-muted small p-2">Nessuna pratica attiva.</div>
                    }
                </div>
            </div>
        </div>

        <!-- Avvisi Parcella -->
        <div class="col-md-4 col-sm-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-success text-white">
                    <i class="bi bi-receipt-cutoff me-1"></i> Avvisi Parcella
                </div>
                <div class="card-body p-0">
                    @if (Model.AvvisiParcella?.Any() == true)
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var av in Model.AvvisiParcella.Take(5))
                            {
                                <li class="list-group-item small d-flex justify-content-between">
                                    <span>@av.TitoloAvviso</span>
                                    <a href="@Url.Action("GestioneParcelle", "Pratiche", new { id = av.ID_AvvisoParcelle })" class="text-success">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-muted small p-2">Nessun avviso disponibile.</div>
                    }
                </div>
            </div>
        </div>

        <!-- ✅ Notifiche Recenti -->
        <div class="col-md-4 col-sm-6">
            <div class="card h-100">
                <div class="card-header bg-warning text-dark">
                    <i class="bi bi-bell-fill me-1"></i> Notifiche Recenti
                </div>
                <div class="card-body">
                    @if (Model.Notifiche?.Any() == true)
                    {
                        <ul class="list-group list-group-sm">
                            @foreach (var n in Model.Notifiche)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>@n.Titolo</span>
                                    <div class="d-flex gap-2">
                                        <!-- Vai alla pratica -->
                                        @if (!string.IsNullOrEmpty(n.LinkPratica))
                                        {
                                            <a href="@n.LinkPratica" class="text-warning" title="Vai alla pratica">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </a>
                                        }
                                        <!-- Vedi tutte le notifiche (partial) -->
                                        <a class="btn btn-sm btn-outline-primary p-0 px-1"
                                           href="@Url.Action("NotificheList", "Home", new { stato = "Tutte", tipo = "Tutti" })"
                                           title="Vedi tutte le notifiche">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-muted small">Nessuna notifica recente.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

