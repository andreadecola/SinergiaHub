document.addEventListener("click", function (e) {

    // 🔴 Se clicco snapshot NON fare nulla
    const snapshotLink = e.target.closest(".snapshot-link");
    if (snapshotLink) {
        console.log("📸 Click snapshot → ignoro KPI admin");
        return;
    }

    // 🔴 Verifico se è una KPI
    const card = e.target.closest(".kpi-card");
    if (!card) return;

    // 🔴 Prendo il tipo
    const tipo = card.dataset.tipo;
    if (!tipo) return;

    const titolo = tipo.charAt(0).toUpperCase() + tipo.slice(1);

    const anno = "@annoSelezionato";
    const trimestre = "@Model.FiltroTrimestre";
    const sottoFiltro = "@Model.SottoFiltro";

    console.log("📊 KPI ADMIN cliccata:", { tipo, anno, trimestre, sottoFiltro });

    const modalEl = document.getElementById("modaleDettaglioKPI");
    if (!modalEl) {
        console.error("❌ Modale KPI admin non trovata");
        return;
    }

    const modal = new bootstrap.Modal(modalEl);

    document.getElementById("titoloModaleKPI").innerText =
        `Dettaglio KPI: ${titolo}`;

    document.getElementById("contenutoDettaglioKPI").innerHTML = `
        <div class="text-center text-muted py-4">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 small">Caricamento dati ${titolo}...</p>
        </div>`;

    modal.show();

    const url =
        `/Home/GetDettaglioKPISinergia` +
        `?tipo=${encodeURIComponent(tipo)}` +
        `&anno=${encodeURIComponent(anno)}` +
        `&trimestre=${encodeURIComponent(trimestre)}` +
        `&sottoFiltro=${encodeURIComponent(sottoFiltro)}`;

    console.log("➡️ URL KPI ADMIN:", url);

    fetch(url)
        .then(res => res.text())
        .then(html => {
            document.getElementById("contenutoDettaglioKPI").innerHTML = html;
        })
        .catch(err => {

            console.error("❌ Errore KPI admin:", err);

            document.getElementById("contenutoDettaglioKPI").innerHTML =
                `<div class='alert alert-danger mb-0'>
                    Errore nel caricamento: ${err.message}
                </div>`;
        });

});
        </script>

