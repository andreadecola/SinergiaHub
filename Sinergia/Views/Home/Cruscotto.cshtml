                            </div>

                            <div class="d-flex justify-content-between mt-1">
                                <span>
                                    <span class="badge bg-secondary me-1">Rimb.</span>
                                    Anticipate
                                </span>
                                <span>
                                    @string.Format("{0:N2} €", Model.TotaleRimborsiAnticipatiDocumentale)
                                </span>
                            </div>

                            <div class="d-flex justify-content-between mt-1">
                                <span>
                                    <span class="badge bg-warning text-dark me-1">Rimb.</span>
                                    Urgenti
                                </span>
                                <span>
                                    @string.Format("{0:N2} €", Model.TotaleRimborsiUrgentiDocumentale)
