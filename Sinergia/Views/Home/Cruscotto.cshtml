            <!-- 1️⃣ Avvisi Parcella Totali -->
            <div class="col-md-3 col-sm-6">
                <div class="card shadow-sm border-0 h-100 kpi-card" data-tipo="avvisi">
                    <div class="card-body p-3">
                        <i class="bi bi-receipt fs-4 text-primary"></i>
                        <h6 class="mt-2 fw-bold">@Model.AvvisiTotaliSinergia</h6>
                        <p class="mb-0 small text-muted">Avvisi Parcella Totali</p>
                    </div>
                </div>
            </div>

