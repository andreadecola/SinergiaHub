@model Sinergia.Models.DashboardViewModel
@{
    ViewBag.Title = "Cruscotto";

    // ✅ Calcola l'anno selezionato
    int annoCorrente = DateTime.Now.Year;
    int annoSelezionato = annoCorrente;

    var annoRequest = Request["annoSelezionato"];
    if (!string.IsNullOrEmpty(annoRequest))
    {
        int parsed;
        if (int.TryParse(annoRequest, out parsed))
        {
            annoSelezionato = parsed;
        }
    }
}


<script>
    document.addEventListener("click", function (e) {

        const link = e.target.closest(".snapshot-link");
        if (!link) return;

        e.preventDefault();
        e.stopPropagation();

        const tipo = link.dataset.tipo;
        const id = link.dataset.id;

        console.log("📸 SNAPSHOT CLICK:", tipo, id);

        apriSnapshot(tipo, id);

    });
</script>

@*MI RAPPRESENTA IL DETTAGLIO DELLA PRATICA AVVISO PARCELLA E INCASSO*@

<div class="modal fade" id="globalSnapshotModal" tabindex="-1">

    <div class="modal-dialog modal-xl">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title" id="snapshotTitle">
                    Snapshot
                </h5>

                <button class="btn-close" data-bs-dismiss="modal"></button>

            </div>

            <div class="modal-body" id="snapshotBody">

                <div class="text-center p-4">
                    Caricamento...
                </div>

            </div>

        </div>

    </div>

</div>

<script>

    function apriSnapshot(tipo, id) {

        // 🔴 chiude la modale KPI se aperta
        const kpiModal = document.getElementById("modaleDettaglioKPI");

        if (kpiModal && kpiModal.classList.contains("show")) {
            const kpiInstance = bootstrap.Modal.getOrCreateInstance(kpiModal);
            kpiInstance.hide();
        }

        // 🔴 chiude modale KPI Professionista
        const kpiProfModal = document.getElementById("modaleDettaglioKPIProf");
        if (kpiProfModal && kpiProfModal.classList.contains("show")) {
            const kpiProfInstance = bootstrap.Modal.getOrCreateInstance(kpiProfModal);
            kpiProfInstance.hide();
        }

        const modalElement = document.getElementById("globalSnapshotModal");
        const modal = bootstrap.Modal.getOrCreateInstance(modalElement);

        const body = document.getElementById("snapshotBody");
        const title = document.getElementById("snapshotTitle");

        body.innerHTML = "Caricamento snapshot...";

        // 🔴 aspetta che la KPI si chiuda
        setTimeout(() => {

            modal.show();

            fetch('/Snapshot/GetSnapshot?tipo=' + tipo + '&id=' + id)
                .then(r => r.json())
                .then(data => {

                    if (!data.success) {
                        body.innerHTML =
                            "<div class='alert alert-warning'>Snapshot non disponibile</div>";
                        return;
                    }

                    const snap = JSON.parse(data.snapshot);

                    if (tipo === "PRATICA") {
                        title.innerText = "Snapshot Pratica";
                        renderSnapshotPratica(snap);
                    }

                    if (tipo === "AVVISO") {
                        title.innerText = "Snapshot Avviso Parcella";
                        renderSnapshotAvviso(snap);
                    }

                    if (tipo === "INCASSO") {
                        title.innerText = "Snapshot Incasso";
                        renderSnapshotIncasso(snap);
                    }

                })
                .catch(err => {

                    console.error(err);

                    body.innerHTML =
                        "<div class='alert alert-danger'>Errore caricamento snapshot</div>";
                });

        }, 200);

    }
    function renderSnapshotPratica(p) {

        const body = document.getElementById("snapshotBody");

        function field(label, value) {
            return `
            <div class="col-md-4 mb-2">
                <small class="text-muted">${label}</small>
                <div class="fw-semibold">${value ?? "-"}</div>
            </div>`;
        }

        let html = `
                <div class="container-fluid">

                    <!-- CARD DATI PRATICA -->
                    <div class="card shadow-sm mb-3">

                        <div class="card-header bg-light fw-bold">
                            <i class="bi bi-folder2-open"></i> Dati pratica
                        </div>

                        <div class="card-body">

                            <div class="row">

                                ${field("Titolo", p.Titolo)}
                                ${field("Tipologia", p.Tipologia)}
                                ${field("Oggetto", p.OggettoPratica)}
                                ${field("Stato", `<span class="badge bg-primary">${p.Stato ?? "-"}</span>`)}
                                ${field("Data Inizio Attività", formatDate(p.DataInizioAttivitaStimata))}
                                ${field("Data Fine Attività", formatDate(p.DataFineAttivitaStimata))}
                                ${field("Budget", `<span class="fw-bold text-success">${(p.Budget || 0)} €</span>`)}

                            </div>

                        </div>

                    </div>
                `;

        // ======================
        // COMPENSI
        // ======================

        if (p.compensi?.length) {

            html += `
                <div class="card shadow-sm mb-3">

                    <div class="card-header bg-light fw-bold">
                        <i class="bi bi-cash-stack"></i> Compensi
                    </div>

                    <div class="card-body p-0">

                        <table class="table table-hover mb-0">

                        <thead class="table-light">
                            <tr>
                                <th>Descrizione</th>
                                <th style="width:120px">Tipo</th>
                                <th style="width:150px">Categoria</th>
                                <th class="text-end" style="width:120px">Importo</th>
                            </tr>
                        </thead>

                        <tbody>
                `;

            p.compensi.forEach(c => {

                html += `
                    <tr>
                        <td>${c.Descrizione ?? "-"}</td>

                        <td>
                            <span class="badge bg-secondary">
                                ${c.TipoCompenso ?? "-"}
                            </span>
                        </td>

                        <td>${c.Categoria ?? "-"}</td>

                        <td class="text-end fw-bold text-success">
                            ${c.Importo ?? 0} €
                        </td>
                    </tr>
                    `;
            });

            html += `
                    </tbody>
                    </table>

                        </div>

                    </div>
                    `;
        }

        // ======================
        // UTENTI ASSOCIATI
        // ======================

        if (p.utentiAssociati?.length) {

            html += `
                    <div class="card shadow-sm mb-3">

                        <div class="card-header bg-light fw-bold">
                            <i class="bi bi-people"></i> Utenti associati
                        </div>

                        <div class="list-group list-group-flush">
                    `;

            p.utentiAssociati.forEach(u => {

                const nome = u.Nome ? u.Nome : ("Utente ID: " + u.ID_Utente);

                html += `
                    <div class="list-group-item d-flex justify-content-between align-items-center">

                        <div>
                            <i class="bi bi-person-circle me-1"></i>
                            ${nome}
                        </div>

                        <span class="badge bg-info text-dark">
                            ${u.Ruolo ?? "-"}
                        </span>

                    </div>
                    `;
            });

            html += `</div></div>`;
        }


        // ======================
        // DOCUMENTI INCARICO
        // ======================

        if (p.incarichi?.length) {

            html += `
                    <div class="card shadow-sm">

                        <div class="card-header bg-light fw-bold">
                            <i class="bi bi-file-earmark-text"></i> Documenti incarico
                        </div>

                        <div class="card-body p-0">

                            <table class="table table-sm table-hover mb-0">

                            <thead class="table-light">
                                <tr>
                                    <th>Documento</th>
                                    <th style="width:150px">Stato</th>
                                </tr>
                            </thead>

                            <tbody>
                    `;

            p.incarichi.forEach(d => {

                const badge =
                    d.Stato === "Firmato"
                        ? "bg-success"
                        : "bg-secondary";

                html += `
                    <tr>

                        <td>
                            <i class="bi bi-file-earmark-pdf text-danger me-1"></i>
                            ${d.NomeFile}
                        </td>

                        <td>
                            <span class="badge ${badge}">
                                ${d.Stato}
                            </span>
                        </td>

                    </tr>
                    `;
            });

            html += `
                            </tbody>
                            </table>

                        </div>

                    </div>
                    `;
        }

        html += `</div>`;

        body.innerHTML = html;
    }

    function renderSnapshotAvviso(a) {

        const body = document.getElementById("snapshotBody");

        function field(label, value) {
            return `
            <div class="col-md-6 mb-2">
                <small class="text-muted">${label}</small>
                <div class="fw-semibold">${value ?? "-"}</div>
            </div>`;
        }

        let html = `
                    <div class="container-fluid">

                    <!-- ============================= -->
                    <!-- DATI AVVISO -->
                    <!-- ============================= -->

                    <div class="card shadow-sm mb-3">

                    <div class="card-header bg-light fw-bold">
                    <i class="bi bi-receipt"></i> Avviso Parcella
                    </div>

                    <div class="card-body">

                    <div class="row">

                    ${field("Titolo Avviso", a.TitoloAvviso)}
                    ${field("Pratica", a.pratica?.Titolo)}

                    ${field("Anno pratica", a.pratica?.AnnoProgressivo)}
                    ${field("Numero pratica", a.pratica?.ProgressivoAnno)}

                    ${field("Data Avviso", formatDate(a.DataAvviso))}
                    ${field("Data Invio", formatDate(a.DataInvio))}

                    ${field("Competenza Economica", formatDate(a.DataCompetenzaEconomica))}

                    ${field("Stato", `<span class="badge bg-primary">${a.Stato ?? "-"}</span>`)}

                    ${field("Tipologia Avviso", a.TipologiaAvviso)}
                    ${field("Regime Fiscale", a.RegimeFiscale)}

                    ${field("Metodo Pagamento", a.MetodoPagamento)}

                    ${field("Importo", `<span class="text-success fw-bold">${a.Importo || 0} €</span>`)}

                    ${field("Acconto", (a.ImportoAcconto || 0) + " €")}

                    ${field("Totale Avviso", `<span class="fw-bold text-primary">${a.TotaleAvvisiParcella || 0} €</span>`)}

                    </div>

                    </div>
                    </div>
                    `;

        // =============================
        // RIEPILOGO FISCALE (compatto)
        // =============================

        html += `
                    <div class="card shadow-sm mb-3">

                    <div class="card-header bg-light fw-bold">
                    <i class="bi bi-calculator"></i> Riepilogo fiscale
                    </div>

                    <div class="card-body p-0">

                    <table class="table table-sm table-striped mb-0">

                    <tbody>

                    <tr>
                    <td>Spese Generali</td>
                    <td>${a.RimborsoSpesePercentuale || 0}%</td>
                    <td class="text-end">${a.ImportoRimborsoSpese || 0} €</td>
                    </tr>

                    <tr>
                    <td>Contributo Integrativo</td>
                    <td>${a.ContributoIntegrativoPercentuale || 0}%</td>
                    <td class="text-end">${a.ContributoIntegrativoImporto || 0} €</td>
                    </tr>

                    <tr>
                    <td>IVA</td>
                    <td>${a.AliquotaIVA || 0}%</td>
                    <td class="text-end">${a.ImportoIVA || 0} €</td>
                    </tr>

                    </tbody>
                    </table>

                    </div>
                    </div>
                    `;

        // =============================
        // COMPENSO
        // =============================

        if (a.compenso) {

            html += `
                    <div class="card shadow-sm mb-3">

                    <div class="card-header bg-light fw-bold">
                    <i class="bi bi-cash-stack"></i> Compenso
                    </div>

                    <div class="card-body p-0">

                    <table class="table table-sm table-hover mb-0">

                    <thead class="table-light">
                    <tr>
                    <th>Descrizione</th>
                    <th style="width:120px">Tipo</th>
                    <th class="text-end" style="width:120px">Importo</th>
                    </tr>
                    </thead>

                    <tbody>

                    <tr>
                    <td>${a.compenso.Descrizione ?? "-"}</td>
                    <td>
                    <span class="badge bg-secondary">
                    ${a.compenso.TipoCompenso ?? "-"}
                    </span>
                    </td>
                    <td class="text-end fw-bold text-success">
                    ${a.compenso.Importo ?? 0} €
                    </td>
                    </tr>

                    </tbody>
                    </table>

                    </div>
                    </div>
                    `;
        }

        // =============================
        // INCASSI
        // =============================

        if (a.incassi?.length) {

            html += `
                    <div class="card shadow-sm mb-3">

                    <div class="card-header bg-light fw-bold">
                    <i class="bi bi-cash"></i> Incassi
                    </div>

                    <div class="card-body p-0">

                    <table class="table table-sm table-hover mb-0">

                    <thead class="table-light">
                    <tr>
                    <th>Data</th>
                    <th class="text-end">Importo</th>
                    </tr>
                    </thead>

                    <tbody>
                    `;

            a.incassi.forEach(i => {

                html += `
                    <tr>
                    <td>${formatDate(i.DataIncasso)}</td>
                    <td class="text-end fw-bold text-success">
                    ${i.Importo ?? 0} €
                    </td>
                    </tr>
                    `;
            });

            html += `
                    </tbody>
                    </table>

                    </div>
                    </div>
                    `;
        }

        // =============================
        // DOCUMENTI
        // =============================

        if (a.documenti?.length) {

            html += `
                        <div class="card shadow-sm">

                        <div class="card-header bg-light fw-bold">
                        <i class="bi bi-file-earmark-text"></i> Documenti
                        </div>

                        <div class="list-group list-group-flush">
                        `;

            a.documenti.forEach(d => {

                html += `
                        <div class="list-group-item d-flex justify-content-between">

                        <span>
                        <i class="bi bi-file-earmark-pdf text-danger me-1"></i>
                        ${d.NomeFile}
                        </span>

                        <span class="badge bg-secondary">
                        ${d.Stato ?? "-"}
                        </span>

                        </div>
                        `;
            });

            html += `
                        </div>
                        </div>
                        `;
        }

        html += `</div>`;

        body.innerHTML = html;
    }

    function renderSnapshotIncasso(i) {

        const body = document.getElementById("snapshotBody");

        function field(label, value) {
            return `
                <div class="col-md-6 mb-2">
                    <small class="text-muted">${label}</small>
                    <div class="fw-semibold">${value ?? "-"}</div>
                </div>`;
        }

        let html = `
                <div class="container-fluid">

                <!-- ========================= -->
                <!-- DATI INCASSO -->
                <!-- ========================= -->

                <div class="card shadow-sm mb-3">

                <div class="card-header bg-light fw-bold">
                <i class="bi bi-cash-stack"></i> Incasso
                </div>

                <div class="card-body">

                <div class="row">

                ${field("Pratica", i.pratica?.Titolo)}
                ${field("Titolo Avviso", i.avviso?.TitoloAvviso)}

                ${field("Anno pratica", i.pratica?.AnnoProgressivo)}
                ${field("Numero pratica", i.pratica?.ProgressivoAnno)}

                ${field("Data Incasso", formatDate(i.DataIncasso))}
                ${field("Competenza Economica", formatDate(i.DataCompetenzaEconomica))}

                ${field("Competenza Finanziaria", formatDate(i.DataCompetenzaFinanziaria))}

                ${field("Stato Incasso",
            `<span class="badge bg-success">${i.StatoIncasso ?? "-"}</span>`)}

                ${field("Versa in Plafond",
                i.VersaInPlafond
                    ? `<span class="badge bg-info text-dark">Si</span>`
                    : `<span class="badge bg-secondary">No</span>`)}

                ${field("Modalità pagamento", i.ModalitaPagamento)}

                ${field("Importo Incasso",
                        `<span class="fw-bold text-success">${i.Importo || 0} €</span>`)}

                ${field("Importo Netto",
                            `<span class="fw-bold text-primary">${i.ImportoNetto || 0} €</span>`)}

                </div>

                </div>
                </div>
                `;

        // =========================
        // AVVISO COLLEGATO
        // =========================

        if (i.avviso) {

            html += `
                <div class="card shadow-sm mb-3">

                <div class="card-header bg-light fw-bold">
                <i class="bi bi-receipt"></i> Avviso Parcella
                </div>

                <div class="card-body p-0">

                <table class="table table-sm table-hover mb-0">

                <thead class="table-light">
                <tr>
                <th>Compenso</th>
                <th>Contributo</th>
                <th>IVA</th>
                <th class="text-end">Totale Avviso</th>
                </tr>
                </thead>

                <tbody>

                <tr>
                <td>${i.avviso.Importo ?? 0} €</td>
                <td>${i.avviso.ContributoIntegrativoImporto ?? 0} €</td>
                <td>${i.avviso.ImportoIVA ?? 0} €</td>
                <td class="text-end fw-bold text-primary">
                ${i.avviso.TotaleAvvisiParcella ?? 0} €
                </td>
                </tr>

                </tbody>
                </table>

                </div>
                </div>
                `;
        }


        // =========================
        // NOTE
        // =========================

        if (i.Note) {

            html += `
                <div class="card shadow-sm">

                <div class="card-header bg-light fw-bold">
                <i class="bi bi-chat-left-text"></i> Note
                </div>

                <div class="card-body">

                <div class="alert alert-light border mb-0">
                ${i.Note}
                </div>

                </div>
                </div>
                `;
        }

        html += `</div>`;

        body.innerHTML = html;
    }

    function formatDate(dateString) {

        if (!dateString) return "-";

        const d = new Date(dateString);

        return d.toLocaleDateString("it-IT");
    }
</script>




<style>
    .kpi-card {
        cursor: pointer;
        transition: all 0.2s ease-in-out;
    }

        .kpi-card:hover {
            transform: scale(1.03);
            box-shadow: 0 0 10px rgba(0,0,0,0.15);
        }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">


<div class="container-fluid px-3">

    <!-- Intestazione -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
        <h4 class="mb-2 mb-md-0">
            Benvenuto, @Model.NomeUtente
        </h4>

        @using (Html.BeginForm("Cruscotto", "Home", FormMethod.Get,
            new { @class = "d-flex flex-row flex-wrap gap-2 align-items-center" }))
        {
            <!-- 🗓️ Anno -->
            @Html.DropDownList("annoSelezionato",
              new SelectList(
                  Enumerable.Range(DateTime.Now.Year - 5, 6)
                            .Reverse()
                            .Select(y => new { Value = y, Text = y }),
                  "Value", "Text",
                  annoSelezionato
              ),
              new
              {
                  @class = "form-select form-select-sm shadow-sm",
                  style = "width: 150px;",
                  onchange = "this.form.submit();"
              })

            <!-- 📅 Trimestre -->
            @Html.DropDownList("filtroTrimestre",
                new SelectList(new[]
                {
                    new { Value="Q1", Text="1° Trimestre (Gen - Mar)" },
                    new { Value="Q2", Text="2° Trimestre (Apr - Giu)" },
                    new { Value="Q3", Text="3° Trimestre (Lug - Set)" },
                    new { Value="Q4", Text="4° Trimestre (Ott - Dic)" },
                    new { Value="anno", Text="Anno completo" }
                }, "Value", "Text", Model.FiltroTrimestre),
                new
                {
                    @class = "form-select form-select-sm shadow-sm",
                    style = "width: 220px;",
                    onchange = "this.form.submit();"
                })

            <!-- 🔍 Sottofiltro -->
            @Html.DropDownList("sottoFiltro",
                new SelectList(new[]
                {
                    new { Value="completo", Text="Tutto il trimestre" },
                    new { Value="mese1", Text="1° mese" },
                    new { Value="mese2", Text="2° mese" },
                    new { Value="mese3", Text="3° mese" }
                }, "Value", "Text", Model.SottoFiltro),
                new
                {
                    @class = "form-select form-select-sm shadow-sm",
                    style = "width: 180px;",
                    onchange = "this.form.submit();"
                })
        }
    </div>


    @* 🏢 BLOCCO ADMIN PER KPI SINERGIA *@
