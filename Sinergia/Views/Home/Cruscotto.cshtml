                <div class="card shadow-sm border-0 h-100 kpi-card" data-tipo="crediti">
                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-start">
                            <i class="bi bi-file-earmark-text fs-3 text-warning"></i>

                            <span class="badge bg-light text-dark small">
                                Aggiornato al @DateTime.Now.ToString("dd/MM/yyyy")
                            </span>
                        </div>

                        <!-- 💰 DEBITO TOTALE -->
                        <h4 class="mt-3 fw-bold @(Model.CreditoTotaleProfessionisti >= 0 ? "text-danger" : "text-success")">
                            @string.Format("{0:N2} €", Model.CreditoTotaleProfessionisti)
                        </h4>

                        <p class="mb-2 small text-muted">
                            Debito verso professionisti
                        </p>

                        <hr class="my-2" />

                        <!-- 📆 VARIAZIONE PERIODO -->
                        <div class="small text-muted">
                            <div>
