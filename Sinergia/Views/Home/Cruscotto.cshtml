        <script>
        // ============================
        // 📊 GRAFICO TORTA SINERGIA
        // ============================
        let chartSinergia = null;

        const mapPeriodi = {
            "Q1": "1° Trimestre (Gen - Mar)",
            "Q2": "2° Trimestre (Apr - Giu)",
            "Q3": "3° Trimestre (Lug - Set)",
            "Q4": "4° Trimestre (Ott - Dic)",
            "Anno": "Anno Completo"
        };

        // 🔧 Helper: parse numeri Razor in modo sicuro
        function parseEuro(val) {
            if (!val) return 0;
            // toglie separatori migliaia e normalizza la virgola
            val = val.toString().replace(/\./g, "").replace(",", ".");
            const n = parseFloat(val);
            return isNaN(n) ? 0 : n;
        }

        function aggiornaGraficoSinergia(entrate, uscite, disponibilita, trimestre, sottofiltro) {

            const canvas = document.getElementById('graficoTortaSinergia');
            if (!canvas) {
                console.warn("⚠️ Canvas graficoTortaSinergia non trovato.");
                return;
            }

            const ctx = canvas.getContext('2d');
            if (chartSinergia) chartSinergia.destroy();

            const data = {
                labels: ['Entrate (Trattenute)', 'Uscite', 'Disponibilità (Margine)'],
                datasets: [{
                    data: [entrate, uscite, disponibilita],
                    backgroundColor: ['#198754', '#dc3545', '#0dcaf0'],
                    borderColor: '#fff',
                    borderWidth: 1
                }]
            };

            chartSinergia = new Chart(ctx, {
                type: 'pie',
                data: data,
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    return context.label + ': ' +
                                        context.parsed.toLocaleString('it-IT', {
                                            style: 'currency',
                                            currency: 'EUR'
                                        });
                                }
                            }
                        }
                    }
                }
            });

            const lbl = document.getElementById("lblPeriodo");
            if (lbl) {
                lbl.innerText = mapPeriodi[trimestre] || trimestre;
            }
        }

        document.addEventListener("DOMContentLoaded", function () {

            const trimestre = "@Model.FiltroTrimestre" || "Anno";
            const sotto = "@Model.SottoFiltro" || "completo";

            const entrate = parseEuro("@Model.EntrateTotaliSinergia");
            const uscite = parseEuro("@Model.UsciteTotaliSinergia");
            const disponibilita = parseEuro("@Model.DisponibilitaSinergia");

            console.log("📊 Grafico Sinergia:", { entrate, uscite, disponibilita, trimestre, sotto });

            aggiornaGraficoSinergia(entrate, uscite, disponibilita, trimestre, sotto);
        });

// ============================
